# ContextEngine Environment Configuration
#
# This .env file is for LOCAL DEVELOPMENT ONLY.
# For global installations, set these as system environment variables:
#   export MODEL_PROVIDER=gemini
#   export GEMINI_API_KEY=your_key_here
#
# Copy this file to .env and fill in your values.

# LLM Provider Configuration
# Choose "claude", "openai", or "gemini"
MODEL_PROVIDER=gemini

# API Keys (set the one you're using)
# Get your keys from:
#   - Anthropic: https://console.anthropic.com/
#   - OpenAI: https://platform.openai.com/api-keys
#   - Google: https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
