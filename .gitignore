# ContextEngine — .gitignore

# =============================================================================
# SECURITY — Never commit these
# =============================================================================
.env
.env.local
.env.production
*.key
*.pem

# =============================================================================
# CONTEXT ENGINE INDEX — Project indexes (generated, never commit)
# =============================================================================
.context-engine/

# =============================================================================
# PROJECT MEMORY — Contains proprietary prompts and architecture decisions
# =============================================================================
CLAUDE.md

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
# UV
# =============================================================================
.uv/
uv.lock

# =============================================================================
# TESTING
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
pytest.xml
test-results/

# =============================================================================
# CHROMADB / VECTOR DATABASE
# =============================================================================
chroma/
*.chroma
chromadb/

# =============================================================================
# MACHINE LEARNING / MODELS
# =============================================================================
*.pt
*.pth
*.bin
*.safetensors
models/
model_cache/
.cache/

# =============================================================================
# NODE / JAVASCRIPT (if adding JS tooling later)
# =============================================================================
node_modules/
.next/
dist/
build/
out/
.nuxt/
.vite/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# EDITORS & IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V3/
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
log/

# =============================================================================
# TEMPORARY FILES
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
tmp/
temp/